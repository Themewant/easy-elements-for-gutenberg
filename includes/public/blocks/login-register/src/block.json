{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "easy-elements-for-gutenberg/login-register",
	"version": "0.1.0",
	"title": "Login | Register",
	"category": "easy-elements-for-gutenberg",
	"description": "AJAX login and registration forms with custom fields, math captcha, messages and full styling.",
	"keywords": [ "login", "register", "form", "user", "account" ],
	"example": {},
	"supports": {
		"html": false,
		"align": [ "wide" ],
		"spacing": {
			"margin": [ "top", "bottom", "left", "right" ]
		}
	},
	"textdomain": "easy-elements-for-gutenberg",
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"render": "file:./render.php",
	"attributes": {
		"blockId": { "type": "string", "default": "" },

		"formType": { "type": "string", "default": "login" },
		"defaultForm": { "type": "string", "default": "login" },
		"redirectAfterLogin": { "type": "string", "default": "" },
		"registerOptions": { "type": "array", "default": [ "auto_login", "redirect" ] },
		"redirectAfterRegister": { "type": "string", "default": "" },
		"showPasswordResetLink": { "type": "boolean", "default": true },
		"rememberMe": { "type": "boolean", "default": true },
		"showAjaxLoader": { "type": "boolean", "default": true },
		"notifyAdminEmail": { "type": "boolean", "default": true },
		"enableMathCaptcha": { "type": "boolean", "default": false },
		"mathCaptchaError": { "type": "string", "default": "Incorrect answer to the math question." },

		"loginFields": {
			"type": "array",
			"default": [
				{ "type": "username", "label": "Username", "placeholder": "Username", "icon": "", "isRequired": true, "staticText": "" },
				{ "type": "password", "label": "Password", "placeholder": "Password", "icon": "", "isRequired": true, "staticText": "" }
			]
		},
		"registerFields": {
			"type": "array",
			"default": [
				{ "type": "user_login", "label": "Username", "placeholder": "Username", "icon": "", "isRequired": true, "minLength": "", "maxLength": "", "width": "", "metaKey": "", "inputType": "text", "staticText": "" },
				{ "type": "user_email", "label": "Email", "placeholder": "Email", "icon": "", "isRequired": true, "minLength": "", "maxLength": "", "width": "", "metaKey": "", "inputType": "text", "staticText": "" },
				{ "type": "user_pass", "label": "Password", "placeholder": "Password", "icon": "", "isRequired": true, "minLength": "8", "maxLength": "", "width": "", "metaKey": "", "inputType": "text", "staticText": "" }
			]
		},
		"showLabel": { "type": "boolean", "default": true },
		"showIcon": { "type": "boolean", "default": false },
		"passwordResetText": { "type": "string", "default": "Forgot your password?" },
		"rememberLabelText": { "type": "string", "default": "Remember Me" },

		"submitButtonText": { "type": "string", "default": "Log In" },
		"registerButtonText": { "type": "string", "default": "Register" },
		"submitButtonIcon": { "type": "string", "default": "" },
		"submitButtonIconPosition": { "type": "string", "default": "after" },

		"showSuccessMessage": { "type": "boolean", "default": true },
		"loginSuccessMessage": { "type": "string", "default": "Login Success!" },
		"registerSuccessMessage": { "type": "string", "default": "Registration Success!" },
		"showErrorMessage": { "type": "boolean", "default": true },
		"loginErrorMessage": { "type": "string", "default": "Login failed! Enter correct email & password." },
		"registerErrorMessage": { "type": "string", "default": "Registration Failed!" },
		"alreadyLoggedInMessage": { "type": "string", "default": "You are already logged in. Goto Homepage" },
		"emptyErrorMessage": { "type": "string", "default": "This field is required." },
		"confirmPassErrorMessage": { "type": "string", "default": "Confirm password not matched" },
		"minLengthErrorMessage": { "type": "string", "default": "Minimum {count} characters required." },
		"maxLengthErrorMessage": { "type": "string", "default": "Maximum {count} characters required." },

		"fieldInputColor": { "type": "string", "default": "" },
		"fieldPlaceholderColor": { "type": "string", "default": "" },
		"fieldBgColor": { "type": "string", "default": "" },
		"fieldTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },
		"fieldPadding": { "type": "object" },
		"fieldMargin": { "type": "object" },
		"fieldRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"fieldBorder": { "type": "object", "default": { "width": 0, "color": "", "style": "solid" } },
		"fieldBoxShadow": { "type": "object", "default": { "x": 0, "y": 0, "b": 0, "s": 0, "c": "rgba(0, 0, 0, 0)" } },
		"iconColor": { "type": "string", "default": "" },
		"iconSize": { "type": "string", "default": "" },

		"labelColor": { "type": "string", "default": "" },
		"labelTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },
		"labelMargin": { "type": "object" },

		"linksColor": { "type": "string", "default": "" },
		"linksHoverColor": { "type": "string", "default": "" },
		"linksTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },

		"submitColor": { "type": "string", "default": "" },
		"submitBg": { "type": "string", "default": "" },
		"submitPadding": { "type": "object" },
		"submitMargin": { "type": "object" },
		"submitWidth": { "type": "string", "default": "" },
		"submitRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"submitBorder": { "type": "object", "default": { "width": 0, "color": "", "style": "solid" } },
		"submitBoxShadow": { "type": "object", "default": { "x": 0, "y": 0, "b": 0, "s": 0, "c": "rgba(0, 0, 0, 0)" } },
		"submitIconSize": { "type": "string", "default": "" },
		"submitHoverColor": { "type": "string", "default": "" },
		"submitHoverBg": { "type": "string", "default": "" },

		"messageTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },
		"msgPadding": { "type": "object" },
		"msgMargin": { "type": "object" },
		"successMessageColor": { "type": "string", "default": "" },
		"errorMessageColor": { "type": "string", "default": "" }
	}
}
