{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "easy-elements-for-gutenberg/category-list",
	"version": "0.1.0",
	"title": "Category List",
	"category": "easy-elements-for-gutenberg",
	"description": "A list or grid of taxonomy terms (categories) with icons and post counts.",
	"keywords": [ "category", "categories", "taxonomy", "term", "list" ],
	"example": {},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"padding": [ "top", "bottom", "left", "right" ],
			"margin": [ "top", "bottom", "left", "right" ]
		}
	},
	"textdomain": "easy-elements-for-gutenberg",
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"attributes": {
		"blockId": { "type": "string", "default": "" },
		"postType": { "type": "string", "default": "post" },
		"taxonomy": { "type": "string", "default": "category" },
		"number": { "type": "string", "default": "0" },
		"orderby": { "type": "string", "default": "name" },
		"order": { "type": "string", "default": "ASC" },
		"hideEmpty": { "type": "boolean", "default": false },
		"showCount": { "type": "boolean", "default": true },
		"showIcon": { "type": "boolean", "default": true },
		"catIcon": { "type": "string", "default": "" },

		"layoutCategory": { "type": "string", "default": "list" },
		"columns": { "type": "string", "default": "3" },
		"columnsTablet": { "type": "string", "default": "2" },
		"columnsMobile": { "type": "string", "default": "1" },
		"itemsGap": { "type": "string", "default": "" },

		"itemPadding": { "type": "object" },
		"itemRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"itemBgColor": { "type": "string", "default": "" },
		"itemBgGradient": { "type": "string", "default": "" },
		"itemBorder": { "type": "object", "default": { "width": 0, "color": "", "style": "solid" } },
		"itemBgHoverColor": { "type": "string", "default": "" },
		"itemBgHoverGradient": { "type": "string", "default": "" },
		"itemBorderColorHover": { "type": "string", "default": "" },

		"iconSize": { "type": "string", "default": "" },
		"iconColor": { "type": "string", "default": "" },
		"iconColorHover": { "type": "string", "default": "" },
		"iconSpacing": { "type": "string", "default": "" },

		"nameColor": { "type": "string", "default": "" },
		"nameColorHover": { "type": "string", "default": "" },
		"nameTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },

		"countColor": { "type": "string", "default": "" },
		"countTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } }
	}
}
