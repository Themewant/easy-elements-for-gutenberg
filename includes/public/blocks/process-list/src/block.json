{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "easy-elements-for-gutenberg/process-list",
	"version": "0.1.0",
	"title": "Process List",
	"category": "easy-elements-for-gutenberg",
	"description": "A single process / step row with a big number, icon, title (with highlight) and description.",
	"keywords": [ "process", "step", "icon box", "list", "service" ],
	"example": {},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"padding": [ "top", "bottom", "left", "right" ],
			"margin": [ "top", "bottom", "left", "right" ]
		}
	},
	"textdomain": "easy-elements-for-gutenberg",
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"attributes": {
		"blockId": { "type": "string", "default": "" },
		"icon": { "type": "string", "default": "eelfg-icon-favorite" },
		"title": { "type": "string", "default": "Initial Consultation" },
		"description": { "type": "string", "default": "We start by understanding your vision, needs, lifestyle, and budget to establish the foundation of your project." },
		"link": { "type": "string", "default": "" },
		"linkNewTab": { "type": "boolean", "default": false },
		"linkNofollow": { "type": "boolean", "default": false },
		"processNumber": { "type": "string", "default": "01" },
		"titleTag": { "type": "string", "default": "h3" },
		"alignVertical": { "type": "string", "default": "center" },
		"itemGap": { "type": "string", "default": "64" },

		"iconColor": { "type": "string", "default": "" },
		"iconBgColor": { "type": "string", "default": "" },
		"iconBgGradient": { "type": "string", "default": "" },
		"iconSize": { "type": "string", "default": "" },
		"iconBorder": { "type": "object", "default": { "width": 0, "color": "", "style": "solid" } },
		"iconRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"iconPadding": { "type": "object" },
		"iconBoxShadow": { "type": "object", "default": { "x": 0, "y": 0, "b": 0, "s": 0, "c": "rgba(0, 0, 0, 0)" } },
		"iconBoxSize": { "type": "string", "default": "" },

		"titleColor": { "type": "string", "default": "" },
		"titleTypography": {
			"type": "object",
			"default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" }
		},
		"titleMargin": { "type": "object" },

		"titleSubColor": { "type": "string", "default": "" },
		"titleSubTypography": {
			"type": "object",
			"default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" }
		},
		"titleSubMargin": { "type": "object" },

		"descColor": { "type": "string", "default": "" },
		"descTypography": {
			"type": "object",
			"default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" }
		},

		"numberColor": { "type": "string", "default": "" },
		"numberTypography": {
			"type": "object",
			"default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" }
		}
	}
}
