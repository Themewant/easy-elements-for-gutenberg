{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "easy-elements-for-gutenberg/breadcrumb",
	"version": "0.1.0",
	"title": "Breadcrumb",
	"category": "easy-elements-for-gutenberg",
	"description": "A dynamic breadcrumb trail for the current page, with home icon, separator and full styling.",
	"keywords": [ "breadcrumb", "navigation", "path", "trail" ],
	"example": {},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": [ "top", "bottom", "left", "right" ],
			"padding": [ "top", "bottom", "left", "right" ]
		}
	},
	"textdomain": "easy-elements-for-gutenberg",
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"attributes": {
		"blockId": { "type": "string", "default": "" },
		"showHomeIcon": { "type": "boolean", "default": true },
		"homeIcon": { "type": "string", "default": "" },
		"homeTitle": { "type": "string", "default": "Home" },
		"showCategoryPath": { "type": "boolean", "default": true },
		"showSeparatorIcon": { "type": "boolean", "default": false },
		"separatorIcon": { "type": "string", "default": "" },

		"textColor": { "type": "string", "default": "" },
		"activeColor": { "type": "string", "default": "" },
		"textTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },
		"textPadding": { "type": "object" },
		"textPaddingActive": { "type": "object" },
		"textBgColor": { "type": "string", "default": "" },
		"textBgColorActive": { "type": "string", "default": "" },
		"textRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"textRadiusActive": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },

		"homeIconColor": { "type": "string", "default": "" },
		"homeIconBg": { "type": "string", "default": "" },
		"homeIconSize": { "type": "string", "default": "" },
		"homeIconRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"homeIconPadding": { "type": "object" },
		"homeIconPosY": { "type": "string", "default": "" },
		"homeIconPosX": { "type": "string", "default": "" },

		"separatorColor": { "type": "string", "default": "" },
		"separatorBg": { "type": "string", "default": "" },
		"separatorRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"separatorPadding": { "type": "object" },
		"separatorSize": { "type": "string", "default": "" },
		"separatorGap": { "type": "object" },
		"separatorPosY": { "type": "string", "default": "" },
		"separatorPosX": { "type": "string", "default": "" }
	}
}
