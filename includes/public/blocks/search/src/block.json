{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "easy-elements-for-gutenberg/search",
	"version": "0.1.0",
	"title": "Search",
	"category": "easy-elements-for-gutenberg",
	"description": "A site search — popup lightbox skin or inline search field skin, with full styling.",
	"keywords": [ "search", "input", "field", "popup", "form" ],
	"example": {},
	"supports": {
		"html": false,
		"spacing": {
			"margin": [ "top", "bottom", "left", "right" ]
		}
	},
	"textdomain": "easy-elements-for-gutenberg",
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"render": "file:./render.php",
	"attributes": {
		"blockId": { "type": "string", "default": "" },
		"selectStyle": { "type": "string", "default": "1" },
		"searchTitle": { "type": "string", "default": "" },
		"placeholder": { "type": "string", "default": "Type keywords here..." },
		"openIcon": { "type": "string", "default": "" },
		"closeIcon": { "type": "string", "default": "" },

		"iconSize": { "type": "string", "default": "" },
		"iconColor": { "type": "string", "default": "" },
		"iconVerticalPosition": { "type": "string", "default": "" },
		"iconPositionSide": { "type": "string", "default": "right" },
		"iconOffsetRight": { "type": "string", "default": "" },
		"iconOffsetLeft": { "type": "string", "default": "" },

		"inputTypography": {
			"type": "object",
			"default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" }
		},
		"inputTextColor": { "type": "string", "default": "" },
		"placeholderColor": { "type": "string", "default": "" },
		"inputBgColor": { "type": "string", "default": "" },
		"inputPadding": { "type": "object" },
		"inputHeight": { "type": "string", "default": "" },
		"inputFieldWidth": { "type": "string", "default": "" },
		"inputBorderRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"inputBorderColor": { "type": "string", "default": "" },
		"inputFocusBorderColor": { "type": "string", "default": "" },

		"submitIconColor": { "type": "string", "default": "" },
		"submitIconHoverColor": { "type": "string", "default": "" },
		"submitBtnBg": { "type": "string", "default": "" },
		"submitBtnHoverBg": { "type": "string", "default": "" },
		"submitPadding": { "type": "object" },

		"overlayBg": { "type": "string", "default": "" },
		"popupTitleColor": { "type": "string", "default": "" },
		"popupTitleTypography": {
			"type": "object",
			"default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" }
		},
		"closeIconColor": { "type": "string", "default": "" },
		"closeIconSize": { "type": "string", "default": "" }
	}
}
