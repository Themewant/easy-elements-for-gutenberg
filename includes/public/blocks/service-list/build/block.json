{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "easy-elements-for-gutenberg/service-list",
  "version": "0.1.0",
  "title": "Service List",
  "category": "easy-elements-for-gutenberg",
  "description": "A service item with icon / image / number, title, description and read-more — three skins.",
  "keywords": [
    "service",
    "icon box",
    "feature",
    "skin"
  ],
  "example": {},
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "padding": [
        "top",
        "bottom",
        "left",
        "right"
      ],
      "margin": [
        "top",
        "bottom",
        "left",
        "right"
      ]
    }
  },
  "textdomain": "easy-elements-for-gutenberg",
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "attributes": {
    "blockId": {
      "type": "string",
      "default": ""
    },
    "skinStyle": {
      "type": "string",
      "default": "skin1"
    },
    "mediaType": {
      "type": "string",
      "default": "icon"
    },
    "serviceIcon": {
      "type": "string",
      "default": "eelfg-icon-favorite"
    },
    "serviceImage": {
      "type": "object",
      "default": {}
    },
    "title": {
      "type": "string",
      "default": "Managed IT Services"
    },
    "number": {
      "type": "string",
      "default": "1"
    },
    "titleTag": {
      "type": "string",
      "default": "h3"
    },
    "description": {
      "type": "string",
      "default": "Professional monitoring and management of your IT systems 24/7/365, ensuring optimal performance and security."
    },
    "readmoreType": {
      "type": "string",
      "default": "readmore"
    },
    "readmoreText": {
      "type": "string",
      "default": "Read More"
    },
    "readmoreIcon": {
      "type": "string",
      "default": ""
    },
    "readmoreIconSpacing": {
      "type": "string",
      "default": ""
    },
    "readmoreLink": {
      "type": "string",
      "default": "#"
    },
    "linkNewTab": {
      "type": "boolean",
      "default": false
    },
    "linkNofollow": {
      "type": "boolean",
      "default": false
    },
    "readmoreIconColor": {
      "type": "string",
      "default": ""
    },
    "readmoreIconBgColor": {
      "type": "string",
      "default": ""
    },
    "readmoreIconBgGradient": {
      "type": "string",
      "default": ""
    },
    "circleSizeOnlyIcon": {
      "type": "string",
      "default": "100"
    },
    "circleBorderRadiusOnlyIcon": {
      "type": "object",
      "default": {
        "top": "",
        "right": "",
        "bottom": "",
        "left": ""
      }
    },
    "circleIconSizeOnly": {
      "type": "string",
      "default": "25"
    },
    "vAlign": {
      "type": "string",
      "default": ""
    },
    "mediaContentGap": {
      "type": "string",
      "default": ""
    },
    "iconColor": {
      "type": "string",
      "default": ""
    },
    "iconBgColor": {
      "type": "string",
      "default": ""
    },
    "iconBgGradient": {
      "type": "string",
      "default": ""
    },
    "iconSize": {
      "type": "string",
      "default": ""
    },
    "iconPadding": {
      "type": "object"
    },
    "iconBorderRadius": {
      "type": "object",
      "default": {
        "top": "",
        "right": "",
        "bottom": "",
        "left": ""
      }
    },
    "circleBgColor": {
      "type": "string",
      "default": ""
    },
    "circleBgGradient": {
      "type": "string",
      "default": ""
    },
    "circleSize": {
      "type": "string",
      "default": ""
    },
    "circleBorderRadius": {
      "type": "object",
      "default": {
        "top": "",
        "right": "",
        "bottom": "",
        "left": ""
      }
    },
    "circlePadding": {
      "type": "object"
    },
    "circleBorder": {
      "type": "object",
      "default": {
        "width": 0,
        "color": "",
        "style": "solid"
      }
    },
    "numberColor": {
      "type": "string",
      "default": ""
    },
    "numberTypography": {
      "type": "object",
      "default": {
        "fontFamily": "",
        "fontSize": "",
        "fontWeight": "",
        "fontStyle": "",
        "textTransform": "",
        "lineHeight": "",
        "letterSpacing": ""
      }
    },
    "titleColor": {
      "type": "string",
      "default": ""
    },
    "titleTypography": {
      "type": "object",
      "default": {
        "fontFamily": "",
        "fontSize": "",
        "fontWeight": "",
        "fontStyle": "",
        "textTransform": "",
        "lineHeight": "",
        "letterSpacing": ""
      }
    },
    "titleMargin": {
      "type": "object"
    },
    "descColor": {
      "type": "string",
      "default": ""
    },
    "descTypography": {
      "type": "object",
      "default": {
        "fontFamily": "",
        "fontSize": "",
        "fontWeight": "",
        "fontStyle": "",
        "textTransform": "",
        "lineHeight": "",
        "letterSpacing": ""
      }
    },
    "descMargin": {
      "type": "object"
    },
    "readmoreColor": {
      "type": "string",
      "default": ""
    },
    "readmoreTypography": {
      "type": "object",
      "default": {
        "fontFamily": "",
        "fontSize": "",
        "fontWeight": "",
        "fontStyle": "",
        "textTransform": "",
        "lineHeight": "",
        "letterSpacing": ""
      }
    },
    "readmoreBgColor": {
      "type": "string",
      "default": ""
    },
    "readmoreBgGradient": {
      "type": "string",
      "default": ""
    },
    "readmorePadding": {
      "type": "object"
    },
    "readmoreBorderRadius": {
      "type": "object",
      "default": {
        "top": "",
        "right": "",
        "bottom": "",
        "left": ""
      }
    },
    "readmoreBorder": {
      "type": "object",
      "default": {
        "width": 0,
        "color": "",
        "style": "solid"
      }
    },
    "readmoreHoverColor": {
      "type": "string",
      "default": ""
    },
    "readmoreHoverBgColor": {
      "type": "string",
      "default": ""
    },
    "readmoreHoverBgGradient": {
      "type": "string",
      "default": ""
    },
    "readmoreHoverBorderColor": {
      "type": "string",
      "default": ""
    },
    "imageHeight": {
      "type": "string",
      "default": ""
    },
    "imageBorderRadius": {
      "type": "object",
      "default": {
        "top": "",
        "right": "",
        "bottom": "",
        "left": ""
      }
    },
    "circleHoverColor": {
      "type": "string",
      "default": ""
    },
    "lineColor": {
      "type": "string",
      "default": ""
    },
    "lineColorHover": {
      "type": "string",
      "default": ""
    }
  }
}