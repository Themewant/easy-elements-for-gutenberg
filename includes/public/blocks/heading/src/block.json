{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "easy-elements-for-gutenberg/heading",
	"version": "0.1.0",
	"title": "Heading",
	"category": "easy-elements-for-gutenberg",
	"description": "A heading with sub-heading, highlight, separator, gradient text and watermark.",
	"keywords": [ "heading", "title", "subtitle", "text" ],
	"example": {},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"padding": [ "top", "bottom", "left", "right" ],
			"margin": [ "top", "bottom", "left", "right" ]
		}
	},
	"textdomain": "easy-elements-for-gutenberg",
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"attributes": {
		"blockId": { "type": "string", "default": "" },

		"title": { "type": "string", "default": "Heading {{Here}}" },
		"titleTag": { "type": "string", "default": "h2" },
		"linkUrl": { "type": "string", "default": "" },
		"linkTarget": { "type": "boolean", "default": false },
		"linkNofollow": { "type": "boolean", "default": false },
		"showBorderTitle": { "type": "boolean", "default": false },
		"borderPosition": { "type": "string", "default": "eelfg-title-start" },
		"borderColor": { "type": "string", "default": "" },
		"borderPadding": { "type": "object" },
		"showGradientTitle": { "type": "boolean", "default": false },
		"description": { "type": "string", "default": "" },
		"align": { "type": "string", "default": "" },

		"subTitle": { "type": "string", "default": "" },
		"subHeadingType": { "type": "string", "default": "none" },
		"subHeadingIcon": { "type": "string", "default": "" },
		"subHeadingImage": { "type": "object", "default": {} },
		"iconDirection": { "type": "string", "default": "top" },
		"iconColor": { "type": "string", "default": "" },
		"showGradientBorder": { "type": "boolean", "default": false },
		"gradientColor1": { "type": "string", "default": "rgba(0, 0, 0, 0.15)" },
		"gradientColor2": { "type": "string", "default": "rgba(0, 0, 0, 0.30)" },
		"gradientColor3": { "type": "string", "default": "rgba(0, 0, 0, 0.50)" },
		"subGradientBorderPadding": { "type": "object" },
		"gradientBorderRadius": { "type": "string", "default": "40" },

		"separatorType": { "type": "string", "default": "none" },
		"solidColor": { "type": "string", "default": "" },
		"separatorBarWidth": { "type": "string", "default": "" },
		"separatorBarHeight": { "type": "string", "default": "" },
		"selectIcon": { "type": "string", "default": "" },
		"separatorIconColor": { "type": "string", "default": "" },
		"separatorIconSize": { "type": "string", "default": "" },
		"sepImage": { "type": "object", "default": {} },
		"separatorImageWidth": { "type": "string", "default": "" },
		"separatorPosition": { "type": "string", "default": "below" },
		"separatorMargin": { "type": "object" },

		"waterMark": { "type": "string", "default": "" },

		"titleColor": { "type": "string", "default": "" },
		"titleFillColor": { "type": "string", "default": "" },
		"titleFillGradient": { "type": "string", "default": "linear-gradient(68.75deg, #B0FF96 9.78%, #FFF1B5 92.67%)" },
		"titleTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },
		"titleOpacity": { "type": "string", "default": "" },
		"titleStrokeWidth": { "type": "string", "default": "" },
		"titleStrokeColor": { "type": "string", "default": "" },
		"titleTextShadow": { "type": "object", "default": { "x": "", "y": "", "blur": "", "color": "" } },
		"titleBlendMode": { "type": "string", "default": "" },
		"titleMargin": { "type": "object" },
		"titlePadding": { "type": "object" },
		"enableTitleImageFill": { "type": "boolean", "default": false },
		"titleImageFill": { "type": "object", "default": {} },

		"subColor": { "type": "string", "default": "" },
		"subBgColor": { "type": "string", "default": "" },
		"subBgGradient": { "type": "string", "default": "" },
		"subTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },
		"subIconGap": { "type": "string", "default": "" },
		"subIconMargin": { "type": "object" },
		"subIconSize": { "type": "string", "default": "" },
		"subImageWidth": { "type": "string", "default": "" },
		"subImageHeight": { "type": "string", "default": "" },
		"subImageRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"subBorder": { "type": "object", "default": { "width": 0, "color": "", "style": "solid" } },
		"subBorderRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"subPadding": { "type": "object" },
		"subMargin": { "type": "object" },

		"highlightColor": { "type": "string", "default": "" },
		"highlightBgColor": { "type": "string", "default": "" },
		"highlightBgGradient": { "type": "string", "default": "" },
		"highlightTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },
		"highlightPadding": { "type": "object" },
		"highlightMargin": { "type": "object" },
		"highlightBorderRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },

		"descColor": { "type": "string", "default": "" },
		"descTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },
		"descMargin": { "type": "object" },
		"descPadding": { "type": "object" },

		"wmColor": { "type": "string", "default": "" },
		"wmStrokeColor": { "type": "string", "default": "rgba(0, 0, 0, 0.3)" },
		"wmStrokeWidth": { "type": "string", "default": "" },
		"wmFontSize": { "type": "string", "default": "" },
		"wmTypography": { "type": "object", "default": { "fontFamily": "", "fontSize": "", "fontWeight": "", "fontStyle": "", "textTransform": "", "lineHeight": "", "letterSpacing": "" } },
		"wmTextShadow": { "type": "object", "default": { "x": "", "y": "", "blur": "", "color": "" } },
		"wmBgColor": { "type": "string", "default": "" },
		"wmBgGradient": { "type": "string", "default": "" },
		"wmBorder": { "type": "object", "default": { "width": 0, "color": "", "style": "solid" } },
		"wmBorderRadius": { "type": "object", "default": { "top": "", "right": "", "bottom": "", "left": "" } },
		"wmPadding": { "type": "object" },
		"wmBoxShadow": { "type": "object", "default": { "x": 0, "y": 0, "b": 0, "s": 0, "c": "rgba(0, 0, 0, 0)" } },
		"wmTop": { "type": "string", "default": "" },
		"wmLeft": { "type": "string", "default": "" },
		"wmRotation": { "type": "string", "default": "" },
		"wmOpacity": { "type": "string", "default": "" },
		"wmZIndex": { "type": "string", "default": "" },
		"wmBlendMode": { "type": "string", "default": "" }
	}
}
